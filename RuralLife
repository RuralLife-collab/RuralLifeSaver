import os
from flask import Flask, request
import requests

app = Flask(__name__)

# Estas dos variables se configurarán en Render como variables de entorno
TOKEN = os.getenv("TOKEN")
PHONE_NUMBER_ID = os.getenv("PHONE_NUMBER_ID")

@app.route("/", methods=["GET"])
def health():
    return "ok", 200

@app.route("/webhook", methods=["GET", "POST"])
def webhook():
    if request.method == "GET":
        # Debe coincidir con el Verify Token que pondrás en Meta
        verify_token = "ruralmedicos"
        if request.args.get("hub.verify_token") == verify_token:
            return request.args.get("hub.challenge")
        return "Error de verificación", 403

    data = request.json or {}
    try:
        entry = data.get("entry", [])[0]
        changes = entry.get("changes", [])[0]
        value = changes.get("value", {})
        messages = value.get("messages", [])
        if not messages:
            return "no message", 200

        msg = messages[0]
        number = msg.get("from")
        text = (msg.get("text") or {}).get("body", "").lower().strip()

        # Menú educativo básico
        if text == "hola":
            reply = (
                "Hola 👩‍⚕️👨‍⚕️\n"
                "Soy el asistente de *entrenamiento* para médicos rurales.\n\n"
                "Puedo ayudarte con:\n"
                "1️⃣ Emergencias frecuentes\n"
                "2️⃣ Protocolos clínicos\n"
                "3️⃣ Guías rápidas\n"
                "4️⃣ Casos prácticos\n\n"
                "Escribe el número o el tema.\n\n"
                "⚠️ Información educativa; no reemplaza la evaluación clínica."
            )
        elif text == "1":
            reply = (
                "🆘 *Emergencias frecuentes*\n"
                "- Vía aérea: A-B-C.\n"
                "- Shock: IV/IO + cristaloides 30 ml/kg.\n"
                "- Convulsión: diazepam/midazolam según protocolo local.\n"
                "- Referir si no hay respuesta o recursos limitados."
            )
        elif text == "2":
            reply = (
                "📋 *Protocolos clínicos*\n"
                "- Preeclampsia: sulfato de magnesio (régimen Pritchard), "
                "control de PA, referencia oportuna.\n"
                "- Sepsis: antibiótico precoz, fluidos, cultivos si posible."
            )
        elif text == "3":
            reply = (
                "⚡ *Guías rápidas*\n"
                "- Analgesia: escalera OMS.\n"
                "- Asma exacerbada: SABA + esteroide sistémico.\n"
                "- IAM sospecha: AAS si no contraindicado y referencia urgente."
            )
        elif text == "4":
            reply = (
                "🧪 *Caso práctico*\n"
                "Paciente PA 170/110, cefalea intensa, 34 semanas.\n"
                "Escribe *preeclampsia* para ver conducta inicial educativa."
            )
        elif "preeclampsia" in text:
            reply = (
                "🟣 *Preeclampsia – manejo inicial (educativo)*\n"
                "1) Monitorizar PA y signos de alarma.\n"
                "2) Sulfato de magnesio: carga 4 g IV + 10 g IM (según protocolo), "
                "mantenimiento 5 g IM c/4 h alternando glúteos.\n"
                "3) Antihipertensivo (hidralazina/labetalol) si disponible.\n"
                "4) Referir a nivel superior.\n"
                "⚠️ Adapta a guías locales."
            )
        else:
            reply = (
                "Gracias por tu mensaje.\n"
                "Escribe *hola* para ver el menú (1, 2, 3 o 4)."
            )

        # Enviar respuesta por WhatsApp
        requests.post(
            f"https://graph.facebook.com/v18.0/{PHONE_NUMBER_ID}/messages",
            headers={
                "Authorization": f"Bearer {TOKEN}",
                "Content-Type": "application/json"
            },
            json={
                "messaging_product": "whatsapp",
                "to": number,
                "text": {"body": reply}
            },
            timeout=10
        )
    except Exception as e:
        print("ERROR:", e)

    return "ok", 200

if __name__ == "__main__":
    port = int(os.getenv("PORT", "8000"))
    app.run(host="0.0.0.0", port=port)
